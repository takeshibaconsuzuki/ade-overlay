{
  "name": "ade-overlay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:mac": "node scripts/package-mac.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "client:generate": "tsx scripts/generate-client.ts",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "upgrade": "NO_UPDATE_NOTIFIER=1 ncu --peer --removeRange -u && npm install",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "postinstall": "install-electron && npm run rebuild:native"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@radix-ui/themes": "3.3.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "lucide-react": "1.18.0",
    "mustache": "4.2.0",
    "node-pty": "1.1.0",
    "pino": "9.14.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/ws": "8.18.1",
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.98.2",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/mustache": "4.2.6",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.4.0",
    "electron-vite": "5.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "npm-check-updates": "22.2.3",
    "pino-pretty": "13.1.3",
    "playwright": "1.60.0",
    "prettier": "3.8.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5"
  }
}
